# Gmail account that sends the alerts
GMAIL_USER=you@gmail.com

# App password — NOT your normal Gmail password.
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
# Name it "Home Security Pi" or anything you like.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send alerts (defaults to GMAIL_USER if not set)
ALERT_EMAIL=you@gmail.com

# Seconds between alert emails (default 300 = 5 minutes)
COOLDOWN_SECONDS=300

# Inference FPS — lower = less CPU. Active FPS used when a person is in frame.
IDLE_FPS=5
ACTIVE_FPS=15
